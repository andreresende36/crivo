{
  "manifest_version": 3,
  "name": "DealHunter ML Cookie Extractor",
  "version": "1.0",
  "description": "Extrai cookies de sessão do Mercado Livre para o DealHunter (.env)",
  "permissions": ["cookies", "activeTab", "scripting"],
  "host_permissions": ["*://*.mercadolivre.com.br/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
