{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Crivo Runner",
      "runtimeExecutable": "python",
      "runtimeArgs": [
        "-m",
        "crivo.runner"
      ],
      "port": 8000
    },
    {
      "name": "Admin Panel",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev",
        "--prefix",
